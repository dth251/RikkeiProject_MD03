{
    "info": {
        "name": "Course Management API",
        "description": "API collection for Course Management System",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080",
            "type": "string"
        },
        {
            "key": "token",
            "value": "your_jwt_token_here",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "1. Authentication",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"username\": \"admin\", \"password\": \"password\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Me",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/auth/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "me"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Users (Admin)",
            "item": [
                {
                    "name": "Get All Users",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/users",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "users"
                            ]
                        }
                    }
                },
                {
                    "name": "Create User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"new_student\",\n    \"password\": \"password\",\n    \"email\": \"student@example.com\",\n    \"fullName\": \"New Student\",\n    \"role\": \"STUDENT\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/users",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "users"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Courses",
            "item": [
                {
                    "name": "Get All Courses",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/courses",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Course (Admin)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Spring Boot for Beginners\",\n    \"description\": \"Learn Spring Boot from scratch\",\n    \"price\": 100.0,\n    \"teacherId\": 2,\n    \"durationHours\": 40\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/courses",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "4. Lessons",
            "item": [
                {
                    "name": "Get Lessons for Course",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/courses/1/lessons",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses",
                                "1",
                                "lessons"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Lesson (Teacher/Admin)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Introduction to Spring\",\n    \"contentUrl\": \"https://video.url\",\n    \"textContent\": \"Spring is a framework...\",\n    \"orderIndex\": 1\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/courses/1/lessons",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses",
                                "1",
                                "lessons"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "5. Enrollments (Student)",
            "item": [
                {
                    "name": "Get My Enrollments",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/enrollments",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "enrollments"
                            ]
                        }
                    }
                },
                {
                    "name": "Enroll in Course",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"courseId\": 1\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/enrollments",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "enrollments"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}